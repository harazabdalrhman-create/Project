</div>

<nav class="navbar">
  <div class="navbar-inner">
    <a href="index.html" class="navbar-logo">
      <div class="logo-icon"><img src="/assets/images/DUR7PaeXUAM_Tuz.png" alt="Gaming Hub Logo"></div>
      <div class="logo-text">Gaming<span>Hub</span></div>
    </a>
    <ul class="navbar-nav">
      <li><a href="/" class="nav-link active">Home</a></li>
      <li><a href="/games" class="nav-link">Games</a></li>
      <li><a href="/Library" class="nav-link">My Library</a></li>
