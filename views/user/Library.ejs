        <span style="font-family: var(--font-display); font-size: 1.1rem; font-weight: 800; letter-spacing: 0.05em; text-transform: uppercase;">All Library Games</span>
      </div>

      <button id="add-to-library-btn" class="btn btn-primary">+ Add Game</button>
    </div>

    <div class="grid-4" id="library-grid" style="margin-bottom:80px; min-height: 40vh;"></div>

  </div>
