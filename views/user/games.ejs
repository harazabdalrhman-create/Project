<%- include('../includes/head.ejs') %>

<div class="bg-shapes">
  <div class="shape shape-1"></div>
  <div class="shape shape-2"></div>
  <div class="shape shape-5">★</div>
  <div class="shape shape-6">★</div>
</div>

<%- include('../includes/navbar.ejs') %>

<main class="page-wrapper">
  <div class="container">

    <!-- Page Hero -->
    <div class="page-hero">
      <div class="page-hero-label">— Browse</div>
      <h1 class="page-hero-title">All <span>Games</span></h1>
      <div style="font-family:var(--font-body);font-size:1.05rem;color:var(--black);font-weight:500;opacity:0.7;margin-bottom:0">Discover, rate, and review your favourites from our curated collection</div>
    </div>

    <!-- Toolbar -->
    <div class="games-toolbar">
      <div class="search-box">
        <span class="search-icon">🔍</span>
        <input class="search-input" type="text" placeholder="Search games, genres, developers..." />
      </div>
      <div class="filter-tags">
        <button class="filter-tag active" data-filter="all">All</button>
        <button class="filter-tag" data-filter="rpg">RPG</button>
        <button class="filter-tag" data-filter="action">Action</button>
        <button class="filter-tag" data-filter="racing">Racing</button>
        <button class="filter-tag" data-filter="strategy">Strategy</button>
        <button class="filter-tag" data-filter="horror">Horror</button>
        <button class="filter-tag" data-filter="fighting">Fighting</button>
        <button class="filter-tag" data-filter="roguelike">Roguelike</button>
        <button class="filter-tag" data-filter="sports">Sports</button>
      </div>
    </div>

    <!-- Results count -->
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px">
      <div style="font-family:var(--font-mono);font-size:0.75rem;color:rgba(17,17,17,0.6);text-transform:uppercase;letter-spacing:0.08em">Showing 8 games</div>
      <div style="display:flex;gap:8px;align-items:center">
        <span style="font-family:var(--font-mono);font-size:0.7rem;color:rgba(17,17,17,0.5)">Sort:</span>
        <select class="form-select" style="width:auto;padding:6px 32px 6px 12px;font-size:0.8rem">
          <option>Rating: High to Low</option>
          <option>Newest First</option>
          <option>Most Reviewed</option>
          <option>A → Z</option>
        </select>
      </div>
    </div>

    <!-- Games Grid -->
    <div class="grid-4" id="games-grid" style="margin-bottom:64px"></div>

    <!-- Load More -->
    <div style="text-align:center;padding-bottom:80px">
      <button class="btn btn-outline btn-lg" onclick="this.textContent='Loading...';setTimeout(()=>this.textContent='Load More Games →',1500)">Load More Games →</button>
    </div>

  </div>
</main>

<%- include('../includes/footer.ejs') %>

<%- include('../includes/end.ejs') %>