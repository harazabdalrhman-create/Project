<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= pageTitle %></title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

<div class="bg-shapes">
  <div class="shape shape-1"></div>
  <div class="shape shape-2"></div>
  <div class="shape shape-5">★</div>
  <div class="shape shape-6">★</div>
</div>

<nav class="navbar">
  <div class="navbar-inner">
<a href="index.html" class="navbar-logo">
  <div class="logo-icon"><img src="/assets/images/DUR7PaeXUAM_Tuz.png" alt="Gaming Hub Logo"></div>
  <div class="logo-text">Gaming<span>Hub</span></div>
</a>
    <ul class="navbar-nav">
      <li><a href="/" class="nav-link active">Home</a></li>
      <li><a href="/games" class="nav-link">Games</a></li>
      <li><a href="/Library" class="nav-link">My Library</a></li>
      <li><a href="/admin" class="nav-link">Admin</a></li>
    </ul>
    <div class="navbar-actions">
      <a href="login.html" class="btn btn-outline-white btn-sm">Log In</a>
      <a href="register.html" class="btn btn-cyan btn-sm">Sign Up →</a>
      <button class="hamburger" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</nav>

<main class="page-wrapper">
  <div class="container">

    <!-- Page Hero -->
    <div class="page-hero">
      <div class="page-hero-label">— Browse</div>
      <h1 class="page-hero-title">All <span>Games</span></h1>
      <div style="font-family:var(--font-body);font-size:1.05rem;color:var(--black);font-weight:500;opacity:0.7;margin-bottom:0">Discover, rate, and review your favourites from our curated collection</div>
    </div>

    <!-- Toolbar -->
    <div class="games-toolbar">
      <div class="search-box">
        <span class="search-icon">🔍</span>
        <input class="search-input" type="text" placeholder="Search games, genres, developers..." />
      </div>
      <div class="filter-tags">
        <button class="filter-tag active" data-filter="all">All</button>
        <button class="filter-tag" data-filter="rpg">RPG</button>
        <button class="filter-tag" data-filter="action">Action</button>
        <button class="filter-tag" data-filter="racing">Racing</button>
        <button class="filter-tag" data-filter="strategy">Strategy</button>
        <button class="filter-tag" data-filter="horror">Horror</button>
        <button class="filter-tag" data-filter="fighting">Fighting</button>
        <button class="filter-tag" data-filter="roguelike">Roguelike</button>
        <button class="filter-tag" data-filter="sports">Sports</button>
      </div>
    </div>

    <!-- Results count -->
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px">
      <div style="font-family:var(--font-mono);font-size:0.75rem;color:rgba(17,17,17,0.6);text-transform:uppercase;letter-spacing:0.08em">Showing 8 games</div>
      <div style="display:flex;gap:8px;align-items:center">
        <span style="font-family:var(--font-mono);font-size:0.7rem;color:rgba(17,17,17,0.5)">Sort:</span>
        <select class="form-select" style="width:auto;padding:6px 32px 6px 12px;font-size:0.8rem">
          <option>Rating: High to Low</option>
          <option>Newest First</option>
          <option>Most Reviewed</option>
          <option>A → Z</option>
        </select>
      </div>
    </div>

    <!-- Games Grid -->
    <div class="grid-4" id="games-grid" style="margin-bottom:64px"></div>

    <!-- Load More -->
    <div style="text-align:center;padding-bottom:80px">
      <button class="btn btn-outline btn-lg" onclick="this.textContent='Loading...';setTimeout(()=>this.textContent='Load More Games →',1500)">Load More Games →</button>
    </div>

  </div>
</main>

    <footer class="footer">
      <div class="container">
        <div class="footer-grid">
          <div>
            <a
              href="index.html"
              class="navbar-logo"
              style="margin-bottom: 16px; display: flex"
            >
              <div class="logo-icon">
                <img
                  src="../assets/images/DUR7PaeXUAM_Tuz.png"
                  alt="Gaming Hub Logo"
                />
              </div>
              <div class="logo-text">Gaming<span>Hub</span></div>
            </a>
            <p class="footer-brand-desc">
              The definitive gaming review platform. Rate, review, and discover
              your next favourite game with the community.
            </p>
            <div class="footer-social">
              <a href="#" class="social-btn">𝕏</a>
              <a href="#" class="social-btn">in</a>
              <a href="#" class="social-btn">▶</a>
              <a href="#" class="social-btn">📘</a>
            </div>
          </div>
          <div>
            <div class="footer-heading">Platform</div>
            <ul class="footer-links">
              <li><a href="games.html">Browse Games</a></li>
              <li><a href="library.html">My Library</a></li>
              <li><a href="game-details.html">Game Reviews</a></li>
              <li><a href="#">Leaderboard</a></li>
            </ul>
          </div>
          <div>
            <div class="footer-heading">Company</div>
            <ul class="footer-links">
              <li><a href="#">About Us</a></li>
              <li><a href="#">Blog</a></li>
              <li><a href="#">Careers</a></li>
              <li><a href="#">Press</a></li>
            </ul>
          </div>
          <div>
            <div class="footer-heading">Support</div>
            <ul class="footer-links">
              <li><a href="#">Help Center</a></li>
              <li><a href="#">Privacy Policy</a></li>
              <li><a href="#">Terms of Use</a></li>
              <li><a href="#">Contact Us</a></li>
            </ul>
          </div>
        </div>
        <div class="footer-bottom">
          <div class="footer-bottom-text">
            © 2026 Gaming Hub. All rights reserved.
          </div>
          <div class="footer-bottom-text">
            Made with ❤️ for gamers everywhere
          </div>
        </div>
      </div>
    </footer>

<script src="../assets/js/app.js"></script>
</body>
</html>