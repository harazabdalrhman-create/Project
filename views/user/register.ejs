<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <nav class="navbar">
      <div class="navbar-inner">
        <a href="/" class="navbar-logo">
          <div class="logo-icon">
            <img
              src="/assets/images/DUR7PaeXUAM_Tuz.png"
              alt="Gaming Hub Logo"
            />
          </div>
          <div class="logo-text">Gaming<span>Hub</span></div>
        </a>
        <ul class="navbar-nav">
          <li><a href="/" class="nav-link">Home</a></li>
          <li><a href="/games" class="nav-link">Games</a></li>
        </ul>
        <div class="navbar-actions">
          <a href="/login" class="btn btn-outline-white btn-sm">Log In</a>
        </div>
      </div>
    </nav>

    <div class="auth-layout">
      <!-- Left Panel -->
      <div class="auth-left">
        <div class="auth-left-content">
          <div
            style="
              font-family: var(--font-mono);
              font-size: 0.75rem;
              color: var(--cyan);
              text-transform: uppercase;
              letter-spacing: 0.15em;
              margin-bottom: 20px;
            "
          >
            Join PixelVault
          </div>
          <h1 class="auth-headline">
            Start Your<br /><span>Gaming</span><br />Legacy
          </h1>
          <p class="auth-subtext">
            Create your free account and join 42,000+ gamers who rate, review
            and discover incredible games every day.
          </p>

          <div class="auth-features">
            <div class="auth-feature">
              <div class="auth-feature-icon">📚</div>
              <div class="auth-feature-text">
                Build a personal library of every game you've played
              </div>
            </div>
            <div class="auth-feature">
              <div class="auth-feature-icon">✍️</div>
              <div class="auth-feature-text">
                Write detailed reviews and share your honest takes
              </div>
            </div>
            <div class="auth-feature">
              <div class="auth-feature-icon">🔍</div>
              <div class="auth-feature-text">
                Discover hidden gems curated by the community
              </div>
            </div>
            <div class="auth-feature">
              <div class="auth-feature-icon">🎯</div>
              <div class="auth-feature-text">
                Get personalised game recommendations based on your taste
              </div>
            </div>
          </div>

          <!-- Decorative -->
          <div
            style="
              position: absolute;
              bottom: 60px;
              right: 40px;
              display: flex;
              gap: 10px;
              opacity: 0.35;
            "
          >
            <div
              style="
                width: 64px;
                height: 64px;
                background: var(--orange);
                border: 2px solid var(--white);
                border-radius: 50%;
                animation: float1 6s ease-in-out infinite;
              "
            ></div>
            <div
              style="
                width: 40px;
                height: 40px;
                background: var(--pink);
                border: 2px solid var(--white);
                border-radius: 50%;
                animation: float2 8s ease-in-out infinite 2s;
              "
            ></div>
          </div>
        </div>
      </div>

      <!-- Right Panel -->
      <div class="auth-right">
        <div class="auth-form-card">
          <div class="auth-form-title">Create Account</div>
          <div class="auth-form-subtitle">
            It's free — no credit card needed
          </div>

          <!-- Social -->
          <a
            href="#"
            class="btn-social"
            onclick="
              View.showToast('Connecting with Google...', 'info');
              return false;
            "
          >
            <span style="font-size: 1.1rem">G</span> Sign up with Google
          </a>
          <a
            href="#"
            class="btn-social"
            onclick="
              View.showToast('Connecting with Discord...', 'info');
              return false;
            "
          >
            <span style="font-size: 1.1rem">💬</span> Sign up with Discord
          </a>

          <div class="auth-divider">
            <div class="auth-divider-line"></div>
            <div class="auth-divider-text">or fill in the form</div>
            <div class="auth-divider-line"></div>
          </div>

          <form id="register-form">
            <div class="form-row">
              <div class="form-group" style="margin-bottom: 0">
                <label class="form-label">First Name</label>
                <input
                  class="form-input"
                  type="text"
                  name="firstname"
                  placeholder="Alex"
                  required
                />
              </div>
              <div class="form-group" style="margin-bottom: 0">
                <label class="form-label">Last Name</label>
                <input
                  class="form-input"
                  type="text"
                  name="lastname"
                  placeholder="Gamer"
                  required
                />
              </div>
            </div>

            <div class="form-group" style="margin-top: 20px">
              <label class="form-label">Username</label>
              <div style="position: relative">
                <span
                  style="
                    position: absolute;
                    left: 16px;
                    top: 50%;
                    transform: translateY(-50%);
                    font-family: var(--font-mono);
                    font-size: 0.85rem;
                    color: var(--gray);
                  "
                  >@</span
                >
                <input
                  class="form-input"
                  type="text"
                  name="username"
                  placeholder="pixelwarrior99"
                  required
                  style="padding-left: 36px"
                  autocomplete="username"
                />
              </div>
            </div>

            <div class="form-group">
              <label class="form-label">Email Address</label>
              <input
                class="form-input"
                type="email"
                name="email"
                placeholder="gamer@example.com"
                required
                autocomplete="email"
              />
            </div>

            <div class="form-group">
              <label class="form-label">Password</label>
              <div style="position: relative">
                <input
                  class="form-input"
                  type="password"
                  name="password"
                  id="pw1"
                  placeholder="At least 8 characters"
                  required
                  autocomplete="new-password"
                />
                <button
                  type="button"
                  onclick="togglePw('pw1')"
                  style="
                    position: absolute;
                    right: 14px;
                    top: 50%;
                    transform: translateY(-50%);
                    background: none;
                    border: none;
                    cursor: pointer;
                    font-size: 1rem;
                    color: var(--gray);
                  "
                >
                  👁
                </button>
              </div>
              <!-- Strength bar -->
              <div style="margin-top: 8px">
                <div class="progress-bar">
                  <div
                    class="progress-fill"
                    id="password-strength"
                    style="
                      width: 0%;
                      transition:
                        width 0.4s ease,
                        background 0.4s ease;
                    "
                  ></div>
                </div>
                <div
                  style="
                    font-family: var(--font-mono);
                    font-size: 0.65rem;
                    color: var(--gray);
                    margin-top: 4px;
                  "
                >
                  Password strength
                </div>
              </div>
            </div>

            <div class="form-group">
              <label class="form-label">Confirm Password</label>
              <div style="position: relative">
                <input
                  class="form-input"
                  type="password"
                  name="confirm"
                  id="pw2"
                  placeholder="Repeat password"
                  required
                  autocomplete="new-password"
                />
                <button
                  type="button"
                  onclick="togglePw('pw2')"
                  style="
                    position: absolute;
                    right: 14px;
                    top: 50%;
                    transform: translateY(-50%);
                    background: none;
                    border: none;
                    cursor: pointer;
                    font-size: 1rem;
                    color: var(--gray);
                  "
                >
                  👁
                </button>
              </div>
            </div>

            <div class="form-group">
              <label class="form-label">Favourite Genre</label>
              <select class="form-select" name="genre">
                <option value="">Select your main genre...</option>
                <option>Action</option>
                <option>RPG</option>
                <option>Racing</option>
                <option>Strategy</option>
                <option>Horror</option>
                <option>Fighting</option>
                <option>Sports</option>
                <option>Puzzle</option>
              </select>
            </div>

            <div
              style="
                display: flex;
                align-items: flex-start;
                gap: 10px;
                margin-bottom: 28px;
              "
            >
              <input
                type="checkbox"
                id="terms"
                name="terms"
                required
                style="
                  width: 18px;
                  height: 18px;
                  accent-color: var(--cyan);
                  cursor: pointer;
                  margin-top: 2px;
                  flex-shrink: 0;
                "
              />
              <label
                for="terms"
                style="
                  font-family: var(--font-body);
                  font-size: 0.88rem;
                  color: var(--text-muted);
                  cursor: pointer;
                  font-weight: 500;
                  line-height: 1.5;
                "
              >
                I agree to the
                <a href="#" style="color: var(--black); font-weight: 700"
                  >Terms of Service</a
                >
                and
                <a href="#" style="color: var(--black); font-weight: 700"
                  >Privacy Policy</a
                >
              </label>
            </div>

            <button
              type="submit"
              class="btn btn-primary"
              style="width: 100%; padding: 16px; font-size: 0.9rem"
            >
              Create My Account →
            </button>
          </form>

          <div class="auth-switch-text">
            Already have an account? <a href="login.html">Log in</a>
          </div>
        </div>
      </div>
    </div>

    <script src="/js/app.js"></script>
    <script>
      function togglePw(id) {
        const f = document.getElementById(id);
        f.type = f.type === "password" ? "text" : "password";
      }
    </script>
  </body>
</html>
