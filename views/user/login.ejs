<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= pageTitle %></title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

<nav class="navbar">
  <div class="navbar-inner">
    <a href="/" class="navbar-logo">
      <div class="logo-icon">
        <img src="/assets/images/DUR7PaeXUAM_Tuz.png" alt="Gaming Hub Logo" />
      </div>
    </a>
    <ul class="navbar-nav">
      <li><a href="/" class="nav-link">Home</a></li>
      <li><a href="/games" class="nav-link">Games</a></li>
    </ul>
    <div class="navbar-actions">
      <a href="/register" class="btn btn-cyan btn-sm">Create Account →</a>
    </div>
  </div>
</nav>

<div class="auth-layout">
  <!-- Left Panel -->
  <div class="auth-left">
    <div class="auth-left-content">
      <div style="font-family:var(--font-mono);font-size:0.75rem;color:var(--cyan);text-transform:uppercase;letter-spacing:0.15em;margin-bottom:20px">Welcome Back</div>
      <h1 class="auth-headline">Back in<br>the <span>Game</span></h1>
      <p class="auth-subtext">Log in to access your personal library, post reviews, and connect with a community of passionate gamers.</p>

      <div class="auth-features">
        <div class="auth-feature">
          <div class="auth-feature-icon">🎮</div>
          <div class="auth-feature-text">Access your full game library and personal ratings anytime</div>
        </div>
        <div class="auth-feature">
          <div class="auth-feature-icon">⭐</div>
          <div class="auth-feature-text">Post reviews and help other gamers discover great titles</div>
        </div>
        <div class="auth-feature">
          <div class="auth-feature-icon">🏆</div>
          <div class="auth-feature-text">Earn badges and climb the reviewer leaderboard</div>
        </div>
        <div class="auth-feature">
          <div class="auth-feature-icon">🔔</div>
          <div class="auth-feature-text">Get notified when your favourite games drop new updates</div>
        </div>
      </div>

      <!-- Decorative floating dots -->
      <div style="position:absolute;bottom:60px;right:60px;display:flex;gap:12px;opacity:0.4">
        <div style="width:56px;height:56px;background:var(--yellow);border:2px solid var(--white);border-radius:50%;animation:float1 5s ease-in-out infinite"></div>
        <div style="width:36px;height:36px;background:var(--cyan);border:2px solid var(--white);border-radius:50%;animation:float2 7s ease-in-out infinite 1s"></div>
      </div>
    </div>
  </div>

  <!-- Right Panel: Form -->
  <div class="auth-right">
    <div class="auth-form-card">
      <div class="auth-form-title">Log In</div>
      <div class="auth-form-subtitle">Enter your credentials to continue</div>

      <!-- Social Login -->
      <a href="#" class="btn-social" onclick="View.showToast('Connecting with Google...','info');return false">
        <span style="font-size:1.1rem">G</span> Continue with Google
      </a>
      <a href="#" class="btn-social" onclick="View.showToast('Connecting with Discord...','info');return false">
        <span style="font-size:1.1rem">💬</span> Continue with Discord
      </a>

      <div class="auth-divider">
        <div class="auth-divider-line"></div>
        <div class="auth-divider-text">or</div>
        <div class="auth-divider-line"></div>
      </div>

      <!-- Login Form -->
      <form id="login-form">
        <div class="form-group">
          <label class="form-label">Email Address</label>
          <input class="form-input" type="email" name="email" placeholder="gamer@example.com" required autocomplete="email" />
        </div>
        <div class="form-group">
          <label class="form-label" style="display:flex;justify-content:space-between;align-items:center">
            Password
            <a href="#" style="font-family:var(--font-mono);font-size:0.65rem;color:var(--black);font-weight:400;text-decoration:underline">Forgot password?</a>
          </label>
          <div style="position:relative">
            <input class="form-input" type="password" name="password" id="password-field" placeholder="••••••••" required autocomplete="current-password" />
            <button type="button" onclick="togglePw()" style="position:absolute;right:14px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;font-size:1rem;color:var(--gray)">👁</button>
          </div>
        </div>

        <div style="display:flex;align-items:center;gap:10px;margin-bottom:24px">
          <input type="checkbox" id="remember" name="remember" style="width:18px;height:18px;accent-color:var(--cyan);cursor:pointer" />
          <label for="remember" style="font-family:var(--font-body);font-size:0.9rem;color:var(--text-muted);cursor:pointer;font-weight:500">Remember me for 30 days</label>
        </div>

        <button type="submit" class="btn btn-primary" style="width:100%;padding:16px;font-size:0.9rem">Log In →</button>
      </form>

      <div class="auth-switch-text">
        Don't have an account? <a href="register.html">Sign up free</a>
      </div>
    </div>
  </div>
</div>

<script src="/js/app.js"></script>
<script>
  function togglePw() {
    const f = document.getElementById('password-field');
    f.type = f.type === 'password' ? 'text' : 'password';
  }
</script>
</body>
</html>